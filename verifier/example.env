# Verifier service example environment
# Copy to .env and adjust as needed

VERIFIER_PORT=3002
VERIFIER_BASE_URL=http://localhost:3002
ISSUER_BASE_URL=http://localhost:3001
ISSUER_JWKS_URL=http://localhost:3001/.well-known/jwks.json
BBS_KEY_URL=http://localhost:3001/.well-known/bbs-public-key
STATUS_LIST_ID=1
DEMO_MODE=true

# Network privacy via OHTTP relay (Cloudflare Privacy Gateway)
USE_OHTTP=false
OHTTP_RELAY_URL=http://localhost:8787

# Presentation hardening toggles
USE_DPOP=false
USE_WEBAUTHN=false
