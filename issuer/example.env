# Issuer service environment example
ISSUER_PORT=3001
ISSUER_BASE_URL=http://localhost:3001
STATUS_LIST_ID=1
STATUS_LIST_SIZE_BITS=8192
USE_DPOP=true
DEMO_MODE=true
ADMIN_TOKEN=change_me
USE_OHTTP=false
OHTTP_RELAY_URL=https://<your-cloudflare-relay-domain>.workers.dev
# iProov config (sandbox/demo)
IPROOV_BASE_URL=https://eu.rp.iproov.me
IPROOV_API_KEY=replace_with_api_key
IPROOV_MANAGEMENT_KEY=replace_with_management_key
